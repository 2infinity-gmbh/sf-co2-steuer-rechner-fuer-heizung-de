---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="CO2 Steuer Rechner für Heizung - Berechnen Sie Ihre Heizkosten"
  description="Berechnen Sie schnell und einfach die CO2-Steuer für Ihre Heizung. Verstehen Sie die CO2-Bepreisung und finden Sie Einsparmöglichkeiten für Öl, Gas und andere Brennstoffe."
>
  <div class="max-w-4xl mx-auto">
    <!-- Hero Section -->
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        CO2 Steuer Rechner für Heizung
      </h1>
      <p class="text-xl text-gray-600 mb-8">
        Berechnen Sie die CO2-Abgabe für Ihre Heizkosten und entdecken Sie Einsparpotenziale
      </p>
    </div>

    <!-- Calculator Section -->
    <div class="bg-white rounded-lg shadow-lg p-6 md:p-8 mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Heizkosten berechnen</h2>

      <form id="co2-calculator" class="space-y-6">
        <!-- Brennstofftyp -->
        <div>
          <label for="fuel-type" class="block text-sm font-medium text-gray-700 mb-2">
            Brennstofftyp
          </label>
          <select
            id="fuel-type"
            name="fuel-type"
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
          >
            <option value="erdgas">Erdgas</option>
            <option value="heizoel">Heizöl</option>
            <option value="fluessiggas">Flüssiggas</option>
            <option value="kohle">Kohle</option>
          </select>
        </div>

        <!-- Verbrauch -->
        <div>
          <label for="consumption" class="block text-sm font-medium text-gray-700 mb-2">
            Jährlicher Verbrauch
          </label>
          <div class="flex gap-2">
            <input
              type="number"
              id="consumption"
              name="consumption"
              placeholder="z.B. 2000"
              class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
            />
            <select
              id="unit"
              name="unit"
              class="px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
            >
              <option value="kwh">kWh</option>
              <option value="liter">Liter</option>
              <option value="kg">kg</option>
            </select>
          </div>
        </div>

        <!-- Submit Button -->
        <button
          type="submit"
          class="w-full bg-green-600 hover:bg-green-700 text-white font-semibold py-3 px-6 rounded-lg transition shadow-md hover:shadow-lg"
        >
          CO2-Steuer berechnen
        </button>
      </form>

      <!-- Results -->
      <div id="results" class="hidden mt-8 p-6 bg-green-50 border border-green-200 rounded-lg">
        <h3 class="text-xl font-bold text-gray-900 mb-4">Ihre Berechnung</h3>
        <div class="space-y-3">
          <div class="flex justify-between">
            <span class="text-gray-700">CO2-Ausstoß:</span>
            <span id="co2-output" class="font-semibold text-gray-900">-</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-700">CO2-Steuer (2024):</span>
            <span id="tax-2024" class="font-semibold text-gray-900">-</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-700">CO2-Steuer (2025):</span>
            <span id="tax-2025" class="font-semibold text-green-700">-</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Ad Space (Sidebar style on desktop) -->
    <div class="bg-gray-100 rounded-lg p-4 mb-12">
      <div class="h-[250px] flex items-center justify-center bg-gray-200 rounded text-sm text-gray-500">
        Werbung - 300x250
      </div>
    </div>

    <!-- Info Section -->
    <div class="grid md:grid-cols-2 gap-8 mb-12">
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Was ist die CO2-Steuer?</h2>
        <p class="text-gray-600 mb-4">
          Die CO2-Bepreisung ist eine Abgabe auf fossile Brennstoffe wie Heizöl, Erdgas und Kohle. Sie wurde eingeführt, um den Ausstoß von Treibhausgasen zu reduzieren und den Klimaschutz zu fördern.
        </p>
        <p class="text-gray-600">
          Seit 2021 gilt in Deutschland ein CO2-Preis für Wärme und Verkehr. Dieser steigt jährlich an und verteuert damit das Heizen mit fossilen Brennstoffen.
        </p>
      </div>

      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Wie funktioniert der Rechner?</h2>
        <p class="text-gray-600 mb-4">
          Unser CO2 Steuer Rechner ermittelt anhand Ihres Brennstofftyps und Verbrauchs die anfallende CO2-Abgabe. Die Berechnung basiert auf den offiziellen Emissionsfaktoren und aktuellen CO2-Preisen.
        </p>
        <p class="text-gray-600">
          So können Sie Ihre zusätzlichen Heizkosten durch die CO2-Steuer einschätzen und gegebenenfalls über Alternativen wie energetische Sanierung oder einen Heizungswechsel nachdenken.
        </p>
      </div>
    </div>

    <!-- CO2 Price Development -->
    <div class="bg-white rounded-lg shadow p-6 md:p-8 mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Entwicklung des CO2-Preises</h2>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b-2 border-gray-200">
              <th class="text-left py-3 px-4 font-semibold text-gray-900">Jahr</th>
              <th class="text-left py-3 px-4 font-semibold text-gray-900">CO2-Preis</th>
              <th class="text-left py-3 px-4 font-semibold text-gray-900">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <tr>
              <td class="py-3 px-4 text-gray-700">2021</td>
              <td class="py-3 px-4 text-gray-700">25 € / Tonne</td>
              <td class="py-3 px-4 text-gray-500">Abgeschlossen</td>
            </tr>
            <tr>
              <td class="py-3 px-4 text-gray-700">2022</td>
              <td class="py-3 px-4 text-gray-700">30 € / Tonne</td>
              <td class="py-3 px-4 text-gray-500">Abgeschlossen</td>
            </tr>
            <tr>
              <td class="py-3 px-4 text-gray-700">2023</td>
              <td class="py-3 px-4 text-gray-700">30 € / Tonne</td>
              <td class="py-3 px-4 text-gray-500">Abgeschlossen</td>
            </tr>
            <tr class="bg-green-50">
              <td class="py-3 px-4 text-gray-900 font-semibold">2024</td>
              <td class="py-3 px-4 text-gray-900 font-semibold">45 € / Tonne</td>
              <td class="py-3 px-4 text-green-700 font-semibold">Aktuell</td>
            </tr>
            <tr>
              <td class="py-3 px-4 text-gray-700">2025</td>
              <td class="py-3 px-4 text-gray-700">55 € / Tonne</td>
              <td class="py-3 px-4 text-gray-500">Geplant</td>
            </tr>
            <tr>
              <td class="py-3 px-4 text-gray-700">2026</td>
              <td class="py-3 px-4 text-gray-700">55-65 € / Tonne</td>
              <td class="py-3 px-4 text-gray-500">Geplant</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="bg-gradient-to-r from-green-600 to-green-700 rounded-lg shadow-lg p-8 text-center text-white mb-12">
      <h2 class="text-3xl font-bold mb-4">Sparen Sie Heizkosten</h2>
      <p class="text-lg mb-6 opacity-90">
        Nutzen Sie unseren Rechner, um Ihre CO2-Kosten zu ermitteln und entdecken Sie Möglichkeiten zur Reduzierung Ihrer Heizkosten.
      </p>
      <a
        href="#co2-calculator"
        class="inline-block bg-white text-green-700 font-semibold py-3 px-8 rounded-lg hover:bg-gray-100 transition shadow-md"
      >
        Jetzt berechnen
      </a>
    </div>
  </div>

  <!-- Calculator Script -->
  <script>
    const form = document.getElementById('co2-calculator') as HTMLFormElement;
    const results = document.getElementById('results') as HTMLDivElement;
    const co2Output = document.getElementById('co2-output') as HTMLSpanElement;
    const tax2024 = document.getElementById('tax-2024') as HTMLSpanElement;
    const tax2025 = document.getElementById('tax-2025') as HTMLSpanElement;

    // CO2 emission factors (kg CO2 per unit)
    const emissionFactors: Record<string, Record<string, number>> = {
      erdgas: { kwh: 0.201, liter: 0, kg: 0 },
      heizoel: { kwh: 0.266, liter: 2.65, kg: 0 },
      fluessiggas: { kwh: 0.227, liter: 1.64, kg: 0 },
      kohle: { kwh: 0.34, liter: 0, kg: 2.83 }
    };

    // CO2 prices (EUR per tonne)
    const co2Prices = {
      2024: 45,
      2025: 55
    };

    form?.addEventListener('submit', (e) => {
      e.preventDefault();

      const fuelType = (document.getElementById('fuel-type') as HTMLSelectElement).value;
      const consumption = parseFloat((document.getElementById('consumption') as HTMLInputElement).value);
      const unit = (document.getElementById('unit') as HTMLSelectElement).value;

      if (!consumption || consumption <= 0) {
        alert('Bitte geben Sie einen gültigen Verbrauch ein.');
        return;
      }

      // Calculate CO2 emissions in kg
      const emissionFactor = emissionFactors[fuelType][unit] || 0;
      const co2Kg = consumption * emissionFactor;
      const co2Tonnes = co2Kg / 1000;

      // Calculate tax
      const tax24 = co2Tonnes * co2Prices[2024];
      const tax25 = co2Tonnes * co2Prices[2025];

      // Display results
      co2Output.textContent = `${co2Kg.toFixed(2)} kg (${co2Tonnes.toFixed(3)} Tonnen)`;
      tax2024.textContent = `${tax24.toFixed(2)} €`;
      tax2025.textContent = `${tax25.toFixed(2)} €`;

      results.classList.remove('hidden');
      results.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  </script>
</Layout>
